APP_ENV=development
APP_NAME=Khaliduo
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
DEVICE_TOKEN_SECRET=
SALARY_ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
TRUSTED_PROXY_IPS=127.0.0.1,::1
SCREENSHOT_STORAGE_TYPE=local
SCREENSHOT_STORAGE_PATH=./storage/screenshots
DESKTOP_INSTALLER_PATH=../frontend/desktop-agent/release-khaliduo/KhaliduoSetup.exe
DESKTOP_UPDATE_DIRECTORY=../frontend/desktop-agent/release-khaliduo
SCREENSHOT_MAX_FILE_SIZE_MB=10
SCREENSHOT_THUMBNAIL_WIDTH=480
SCREENSHOT_STORAGE_WARNING_PERCENT=75
SCREENSHOT_CLEANUP_INTERVAL_HOURS=6
DEFAULT_SCREENSHOT_INTERVAL_MINUTES=10
DEFAULT_SCREENSHOTS_PER_INTERVAL=1
DEFAULT_IDLE_THRESHOLD_MINUTES=5
DEFAULT_OFFLINE_THRESHOLD_MINUTES=3
DEFAULT_SCREENSHOT_RETENTION_DAYS=30

# Outbound email. Preferred: Microsoft Graph app (client credentials with
# Mail.Send application permission). Fallback: SMTP. If neither is set,
# emails are logged to the console (dev fallback).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER=no-reply@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Khaliduo <no-reply@yourdomain.com>
SMTP_USE_TLS=true
EMAIL_COOLDOWN_MINUTES=15
PASSWORD_RESET_EXPIRE_MINUTES=30
EMPLOYEE_INVITATION_EXPIRE_HOURS=24
EMAIL_ALLOWED_RECIPIENTS=
EMAIL_LOGO_URL=
EMAIL_SUPPORT_ADDRESS=
APP_PUBLIC_URL=http://localhost:5174
