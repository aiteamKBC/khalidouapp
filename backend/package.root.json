{
  "name": "khaliduo",
  "private": true,
  "version": "1.0.0",
  "description": "Khaliduo by Kent Consultancy: desktop app, admin dashboard, and backend.",
  "scripts": {
    "dev:api": "npm --prefix backend run dev",
    "dev:admin": "npm --prefix frontend run dev:admin",
    "dev:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-desktop.ps1",
    "build:admin": "npm --prefix frontend/admin-dashboard run build",
    "build:desktop": "npm --prefix frontend/desktop-agent run build",
    "build:installer": "npm --prefix frontend/desktop-agent run dist",
    "lint:admin": "npm --prefix frontend/admin-dashboard run lint",
    "lint:desktop": "npm --prefix frontend/desktop-agent run lint",
    "test:api": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Set-Location backend; .\\.venv\\Scripts\\python.exe -m pytest\"",
    "validate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validate.ps1"
  }
}
